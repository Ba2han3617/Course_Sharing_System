@{
    ViewBag.Title = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password – CourseNotes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="auth-wrapper">
    <div class="mx-auto" style="width:100%;max-width:440px">
        <div class="auth-card text-center">
            <i class="bi bi-envelope-open-fill text-primary display-4 mb-3"></i>
            <h2 class="fw-bold mb-2">Forgot Password?</h2>
            <p class="text-muted mb-4">Enter your email and we'll send you a reset link.</p>

            <div class="alert alert-info border-0 mb-4">
                <i class="bi bi-info-circle me-2"></i>
                This is a UI demonstration. Email functionality would require SMTP configuration.
            </div>

            <form>
                @Html.AntiForgeryToken()
                <div class="mb-4 text-start">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control" placeholder="your@email.edu" />
                    </div>
                </div>
                <button type="button" class="btn btn-primary w-100 py-2"
                        onclick="showConfirm()">
                    <i class="bi bi-send me-2"></i>Send Reset Link
                </button>
            </form>

            <div id="confirmMsg" class="alert alert-success border-0 mt-3 d-none">
                <i class="bi bi-check-circle me-2"></i>
                If your email is registered, you'll receive a link shortly.
            </div>

            <div class="mt-4">
                <a asp-controller="Auth" asp-action="Login" class="text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Back to login
                </a>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function showConfirm() {
        document.getElementById('confirmMsg').classList.remove('d-none');
    }
</script>
</body>
</html>
