@model CourseNoteSharingSystem.ViewModels.CreateCourseViewModel
@{
    ViewBag.Title = "Add New Course";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-sm btn-link ps-0 text-decoration-none text-muted">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
    <h3 class="fw-bold mt-2">Add New Course</h3>
    <p class="text-muted small">Fill in the details to create a new university course.</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="CourseName" class="form-label fw-medium"></label>
                            <input asp-for="CourseName" class="form-control" placeholder="e.g. Data Structures and Algorithms" />
                            <span asp-validation-for="CourseName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Code" class="form-label fw-medium"></label>
                            <input asp-for="Code" class="form-control" placeholder="e.g. CENG201" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label fw-medium"></label>
                            <select asp-for="Department" class="form-select">
                                <option value="">Select Department</option>
                                <option>Computer Engineering</option>
                                <option>Software Engineering</option>
                                <option>Mathematics</option>
                                <option>Physics</option>
                                <option>Electrical Engineering</option>
                                <option>Industrial Engineering</option>
                                <option>Business Administration</option>
                            </select>
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Semester" class="form-label fw-medium"></label>
                            <select asp-for="Semester" class="form-select">
                                <option value="">Select Semester</option>
                                <option>Fall</option>
                                <option>Spring</option>
                                <option>Summer</option>
                            </select>
                            <span asp-validation-for="Semester" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-medium"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Briefly describe the course content..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-12 mt-4 pt-2 border-top">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-lg me-2"></i>Create Course
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 ms-2">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm bg-primary bg-opacity-10 text-primary h-100">
            <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                <i class="bi bi-info-circle fs-1 mb-3"></i>
                <h5 class="fw-bold">Guideline</h5>
                <p class="small mb-0">Ensure the course code is unique. For example, use 'CENG' prefix for Computer Engineering courses followed by the year and number (e.g., CENG201).</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
