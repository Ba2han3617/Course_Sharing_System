@model CourseNoteSharingSystem.Models.Course
@{
    ViewBag.Title = "Course Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4 d-flex justify-content-between align-items-end">
    <div>
        <a asp-action="Index" class="btn btn-sm btn-link ps-0 text-decoration-none text-muted">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
        <h3 class="fw-bold mt-2">Course Details</h3>
    </div>
    <div class="mb-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-white fw-bold shadow-sm">
            <i class="bi bi-pencil me-1"></i>Edit Course
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 mb-4 border-bottom pb-4">
                    <div class="avatar-lg rounded bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width: 64px; height: 64px; font-size: 1.5rem;">
                        <i class="bi bi-book"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1">@Model.CourseName</h4>
                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2">@Model.Code</span>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-sm-6">
                        <label class="text-muted small text-uppercase fw-bold ls-wider">Department</label>
                        <p class="fw-semibold mb-0">@Model.Department</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small text-uppercase fw-bold ls-wider">Semester</label>
                        <p class="fw-semibold mb-0">@Model.Semester</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small text-uppercase fw-bold ls-wider">Created At</label>
                        <p class="fw-semibold mb-0">@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small text-uppercase fw-bold ls-wider">Last Updated</label>
                        <p class="fw-semibold mb-0">@Model.UpdatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small text-uppercase fw-bold ls-wider">Description</label>
                        <p class="text-body mt-1">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4 bg-light bg-opacity-25">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Quick Stats</h5>
                <div class="d-flex align-items-center justify-content-between mb-3 p-3 bg-white rounded shadow-sm">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-info bg-opacity-10 text-info" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <span class="fw-medium">Total Notes</span>
                    </div>
                    <span class="fw-bold fs-5">@Model.Notes.Count</span>
                </div>
                
                @if (Model.Notes.Any())
                {
                    <h6 class="fw-bold mt-4 mb-3 text-muted">Recent Notes in this course</h6>
                    <ul class="list-unstyled small">
                        @foreach (var note in Model.Notes.OrderByDescending(n => n.UploadDate).Take(5))
                        {
                            <li class="mb-2 p-2 bg-white rounded border-start border-3 border-primary shadow-xs">
                                <a asp-controller="Notes" asp-action="Detail" asp-route-id="@note.Id" class="text-decoration-none text-dark fw-medium">@note.Title</a>
                                <div class="text-muted" style="font-size: 0.75rem;">@note.UploadDate.ToString("MMM dd, yyyy")</div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
