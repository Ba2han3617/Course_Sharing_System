@model CourseNoteSharingSystem.ViewModels.HomeViewModel
@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ═══ HERO ════════════════════════════════════════════════════════════════ -->
<section class="hero-section">
    <div class="container position-relative">
        <div class="row justify-content-center text-center text-white">
            <div class="col-lg-8">
                <div class="section-badge mb-4" style="background:rgba(255,255,255,.15);color:white">
                    <i class="bi bi-stars"></i>
                    University Note Sharing Platform
                </div>
                <h1 class="display-4 fw-black mb-3" style="font-weight:800;letter-spacing:-.03em">
                    Share Knowledge,<br /><span style="opacity:.85">Ace Every Exam</span>
                </h1>
                <p class="lead mb-5 opacity-75">
                    Upload and discover course notes, past exams, and study materials shared by students just like you.
                </p>

                <!-- Hero Search -->
                <form asp-controller="Notes" asp-action="Index" method="get" class="d-flex shadow-lg rounded-pill overflow-hidden bg-white">
                    <input type="text" name="SearchQuery" class="form-control hero-search-bar border-0 flex-grow-1"
                           placeholder="Search notes, courses, topics..." style="border-radius:50px 0 0 50px !important;" />
                    <button type="submit" class="btn btn-primary hero-search-btn">
                        <i class="bi bi-search me-2"></i>Search
                    </button>
                </form>

                <!-- Quick stats -->
                <div class="d-flex justify-content-center gap-4 mt-5 flex-wrap opacity-80">
                    <div class="text-white text-center">
                        <div class="fw-bold fs-4">@Model.TotalNotes+</div>
                        <div class="small opacity-75">Notes Shared</div>
                    </div>
                    <div class="vr opacity-25 d-none d-sm-block"></div>
                    <div class="text-white text-center">
                        <div class="fw-bold fs-4">@Model.TopContributors.Count+</div>
                        <div class="small opacity-75">Contributors</div>
                    </div>
                    <div class="vr opacity-25 d-none d-sm-block"></div>
                    <div class="text-white text-center">
                        <div class="fw-bold fs-4">@Model.Departments.Count</div>
                        <div class="small opacity-75">Departments</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ DEPARTMENTS ══════════════════════════════════════════════════════════ -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <span class="section-badge mb-2"><i class="bi bi-building"></i>Departments</span>
            <h2 class="section-title">Browse by Department</h2>
        </div>
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            @foreach (var dept in Model.Departments)
            {
                <a asp-controller="Notes" asp-action="Index" asp-route-Department="@dept" class="dept-badge">
                    <i class="bi bi-mortarboard me-1"></i>@dept
                </a>
            }
        </div>
    </div>
</section>

<!-- ═══ POPULAR NOTES ════════════════════════════════════════════════════════ -->
<section class="py-5 bg-body-secondary">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <span class="section-badge mb-2"><i class="bi bi-fire"></i>Trending</span>
                <h2 class="section-title mb-0">Most Popular Notes</h2>
            </div>
            <a asp-controller="Notes" asp-action="Index" asp-route-SortBy="mostdownloaded" class="btn btn-outline-primary btn-sm">
                View All <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        @if (Model.PopularNotes.Any())
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
                @foreach (var note in Model.PopularNotes)
                {
                    <div class="col fade-in-up">
                        @await Html.PartialAsync("_NoteCard", note)
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-journal-x empty-icon"></i>
                <h5 class="mt-3">No notes yet</h5>
                <p class="text-muted">Be the first to upload a note!</p>
                <a asp-controller="Notes" asp-action="Upload" class="btn btn-primary">Upload Note</a>
            </div>
        }
    </div>
</section>

<!-- ═══ RECENT NOTES ═════════════════════════════════════════════════════════ -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <span class="section-badge mb-2"><i class="bi bi-clock"></i>Fresh</span>
                <h2 class="section-title mb-0">Recently Uploaded</h2>
            </div>
            <a asp-controller="Notes" asp-action="Index" asp-route-SortBy="newest" class="btn btn-outline-primary btn-sm">
                View All <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        @if (Model.RecentNotes.Any())
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
                @foreach (var note in Model.RecentNotes)
                {
                    <div class="col fade-in-up">
                        @await Html.PartialAsync("_NoteCard", note)
                    </div>
                }
            </div>
        }
    </div>
</section>

<!-- ═══ TOP CONTRIBUTORS ═════════════════════════════════════════════════════ -->
@if (Model.TopContributors.Any())
{
    <section class="py-5 bg-body-secondary">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-badge mb-2"><i class="bi bi-trophy"></i>Leaderboard</span>
                <h2 class="section-title">Top Contributors</h2>
                <p class="text-muted">Students who shared the most knowledge this semester.</p>
            </div>

            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-5 g-4 justify-content-center">
                @foreach (var user in Model.TopContributors)
                {
                    <div class="col fade-in-up">
                        <a asp-controller="Profile" asp-action="View" asp-route-id="@user.UserId" class="text-decoration-none">
                            <div class="contributor-card">
                                @if (!string.IsNullOrEmpty(user.ProfileImage))
                                {
                                    <img src="@user.ProfileImage" class="contributor-avatar" alt="@user.FullName" />
                                }
                                else
                                {
                                    <div class="contributor-avatar-placeholder">@user.FullName[0]</div>
                                }
                                <div class="fw-semibold text-body">@user.FullName</div>
                                <div class="text-muted small">@user.Department</div>
                                <div class="mt-2">
                                    <span class="badge bg-primary">@user.NoteCount notes</span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ═══ CTA ══════════════════════════════════════════════════════════════════ -->
<section class="py-5">
    <div class="container">
        <div class="stats-bar">
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <h2 class="fw-bold mb-2">Ready to contribute?</h2>
                    <p class="opacity-75 mb-0">Share your notes and help fellow students succeed. Earn recognition as a top contributor!</p>
                </div>
                <div class="col-lg-5 text-lg-end">
                    @if (ViewBag.IsAuthenticated == true)
                    {
                        <a asp-controller="Notes" asp-action="Upload" class="btn btn-light btn-lg px-4 fw-semibold">
                            <i class="bi bi-cloud-upload me-2"></i>Upload a Note
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-light btn-lg px-4 fw-semibold me-2">
                            Get Started Free
                        </a>
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-light btn-lg px-4">Login</a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
