@model CourseNoteSharingSystem.ViewModels.NoteDetailViewModel
@{
    ViewBag.Title = Model.Title;
    var stars = (int)Math.Round(Model.AverageRating);
}

@Html.AntiForgeryToken()

<div class="container py-5">
    <div class="row g-5">
        <!-- ── Left Column: Note info ── -->
        <div class="col-lg-8">
            <!-- Header -->
            <div class="note-detail-header mb-4">
                <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                    <div>
                        <span class="badge file-badge-@Model.FileType.ToUpper() mb-2">@Model.FileType.ToUpper()</span>
                        <h1 class="fw-bold h3 mb-2">@Model.Title</h1>
                        <div class="d-flex align-items-center gap-3 flex-wrap opacity-85">
                            <a asp-controller="Profile" asp-action="View" asp-route-id="@Model.UploaderId"
                               class="text-white text-decoration-none d-flex align-items-center gap-1">
                                <i class="bi bi-person-circle"></i>@Model.UploaderName
                            </a>
                            <span><i class="bi bi-book me-1"></i>@Model.CourseName</span>
                            <span><i class="bi bi-calendar me-1"></i>@Model.UploadDate.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                    @if ((string?)ViewBag.UserId == Model.UploaderId || ViewBag.IsAdmin == true)
                    {
                        <div class="dropdown">
                            <button class="btn btn-light btn-sm" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Notes" asp-action="Edit" asp-route-id="@Model.Id">
                                    <i class="bi bi-pencil me-2"></i>Edit
                                </a></li>
                                <li>
                                    <form asp-controller="Notes" asp-action="Delete" method="post"
                                          data-confirm="Are you sure you want to delete this note?">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-trash me-2"></i>Delete
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-semibold mb-2">Description</h5>
                        <p class="text-muted mb-0">@Model.Description</p>
                    </div>
                </div>
            }

            <!-- PDF Preview -->
            @if (Model.FileType == "pdf")
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-semibold mb-3"><i class="bi bi-eye me-2"></i>Preview</h5>
                        <iframe src="@Model.FilePath" class="pdf-preview" title="PDF Preview"></iframe>
                    </div>
                </div>
            }

            <!-- ── Comments ── -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-4">
                        <i class="bi bi-chat-dots me-2"></i>Comments
                        <span class="badge bg-primary ms-2">@Model.Comments.Count</span>
                    </h5>

                    <!-- Comment form -->
                    @if (ViewBag.IsAuthenticated == true)
                    {
                        <form id="commentForm" data-note-id="@Model.Id" class="mb-4">
                            <div class="d-flex gap-3">
                                <div class="avatar-sm rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0">
                                    @(((string?)ViewBag.UserName ?? "U")[0])
                                </div>
                                <div class="flex-grow-1">
                                    <textarea name="content" class="form-control" rows="3"
                                              placeholder="Write a comment..."></textarea>
                                    <button type="submit" class="btn btn-primary btn-sm mt-2">
                                        <i class="bi bi-send me-1"></i>Post Comment
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info border-0 mb-4">
                            <a asp-controller="Auth" asp-action="Login">Login</a> to leave a comment.
                        </div>
                    }

                    <!-- Comment list -->
                    <div id="commentList">
                        @if (Model.Comments.Any())
                        {
                            @foreach (var comment in Model.Comments)
                            {
                                <div class="comment-card" data-comment-id="@comment.Id">
                                    <div class="d-flex align-items-start gap-3">
                                        @if (!string.IsNullOrEmpty(comment.UserAvatar))
                                        {
                                            <img src="@comment.UserAvatar" class="avatar-sm rounded-circle" alt="@comment.UserName" />
                                        }
                                        else
                                        {
                                            <div class="avatar-sm rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0">
                                                @comment.UserName[0]
                                            </div>
                                        }
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <strong>@comment.UserName</strong>
                                                <div class="d-flex align-items-center gap-2">
                                                    <small class="text-muted">@comment.CreatedAt.ToString("MMM dd, yyyy")</small>
                                                    @if ((string?)ViewBag.UserId == comment.UserId || ViewBag.IsAdmin == true)
                                                    {
                                                        <button class="btn btn-sm btn-icon text-danger delete-comment-btn"
                                                                data-comment-id="@comment.Id" title="Delete">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <p class="mb-0 mt-1">@comment.Content</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state py-3">
                                <i class="bi bi-chat-x empty-icon" style="font-size:2rem"></i>
                                <p class="text-muted mt-2 mb-0">No comments yet. Be the first!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Right Column: Actions & Meta ── -->
        <div class="col-lg-4">
            <!-- Download card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-cloud-download-fill text-primary display-5 mb-3"></i>
                    <h5 class="fw-bold mb-1">Download Note</h5>
                    <p class="text-muted small mb-3">Free to download &bull; @Model.FileType.ToUpper() file</p>
                    <a asp-controller="Notes" asp-action="Download" asp-route-id="@Model.Id"
                       class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-download me-2"></i>Download
                    </a>
                    <div class="mt-3 text-muted small">
                        <i class="bi bi-download me-1"></i>@Model.DownloadCount downloads
                    </div>
                </div>
            </div>

            <!-- Interaction card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">Interactions</h6>
                    <div class="d-flex flex-column gap-2">
                        <!-- Like -->
                        <button id="likeBtn" data-note-id="@Model.Id"
                                class="like-btn w-100 justify-content-center @(Model.IsLikedByCurrentUser ? "liked" : "")">
                            <i class="bi @(Model.IsLikedByCurrentUser ? "bi-heart-fill" : "bi-heart")"></i>
                            <span class="like-count">@Model.LikeCount</span> Likes
                        </button>
                        <!-- Favorite -->
                        <button id="favoriteBtn" data-note-id="@Model.Id"
                                class="favorite-btn w-100 justify-content-center @(Model.IsFavoritedByCurrentUser ? "favorited" : "")">
                            <i class="bi @(Model.IsFavoritedByCurrentUser ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                            Save to Favorites
                        </button>
                    </div>
                </div>
            </div>

            <!-- Rating card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-2">Rating</h6>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="display-5 fw-bold" id="avgRating">@Model.AverageRating.ToString("0.0")</span>
                        <div>
                            <div class="star-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= stars ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                                }
                            </div>
                            <div class="text-muted small">
                                <span id="ratingCount">@Model.RatingCount</span> ratings
                            </div>
                        </div>
                    </div>

                    @if (ViewBag.IsAuthenticated == true)
                    {
                        <p class="text-muted small mb-2">Rate this note:</p>
                        <div class="rating-stars" data-note-id="@Model.Id" data-current="@(Model.CurrentUserRating ?? 0)">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi star @(Model.CurrentUserRating.HasValue && i <= Model.CurrentUserRating ? "active bi-star-fill" : "bi-star")"
                                   data-value="@i"></i>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Meta info card -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">Details</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Course</span>
                            <span class="small fw-medium">@Model.CourseName</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Uploaded</span>
                            <span class="small fw-medium">@Model.UploadDate.ToString("MMM dd, yyyy")</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">File Type</span>
                            <span class="badge file-badge-@Model.FileType.ToUpper()">@Model.FileType.ToUpper()</span>
                        </li>
                        <li class="d-flex justify-content-between py-2">
                            <span class="text-muted small">By</span>
                            <a asp-controller="Profile" asp-action="View" asp-route-id="@Model.UploaderId"
                               class="small fw-medium text-decoration-none">@Model.UploaderName</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
