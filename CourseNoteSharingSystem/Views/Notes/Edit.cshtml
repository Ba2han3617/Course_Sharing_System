@model CourseNoteSharingSystem.DTOs.EditNoteDto
@{
    ViewBag.Title = "Edit Note";
    var courses = ViewBag.Courses as List<CourseNoteSharingSystem.ViewModels.CourseSelectItem> ?? new();
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-1"><i class="bi bi-pencil me-2"></i>Edit Note</h1>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label">Note Title *</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CourseId" class="form-label">Course *</label>
                            <select asp-for="CourseId" class="form-select">
                                <option value="">Select a course...</option>
                                @foreach (var c in courses)
                                {
                                    <option value="@c.Id">@c.CourseName – @c.Department</option>
                                }
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary flex-grow-1">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                            <a asp-controller="Notes" asp-action="Detail" asp-route-id="@Model.Id"
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
