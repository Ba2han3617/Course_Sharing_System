<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CourseNotes – The university course note sharing platform. Upload, discover and download study notes." />
    <title>@(ViewBag.Title != null ? $"{ViewBag.Title} | CourseNotes" : "CourseNotes – University Note Sharing")</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- App CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ─── Top Navigation ──────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg cnss-navbar sticky-top" id="mainNavbar">
    <div class="container-fluid px-4">
        <!-- Brand -->
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
            <i class="bi bi-journal-bookmark-fill me-2 text-primary"></i>
            <span class="brand-text">CourseNotes</span>
        </a>

        <!-- Mobile toggle -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Nav links -->
        <div class="collapse navbar-collapse" id="navbarMain">
            <!-- Live Search Bar -->
            <div class="mx-auto nav-search-wrapper">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="globalSearch" class="form-control border-start-0 ps-0"
                           placeholder="Search notes, courses, uploaders..." autocomplete="off" />
                </div>
                <div id="searchDropdown" class="search-dropdown shadow-lg d-none"></div>
            </div>

            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Notes" asp-action="Index">
                        <i class="bi bi-file-earmark-text me-1"></i>Notes
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Courses" asp-action="Index">
                        <i class="bi bi-book me-1"></i>Courses
                    </a>
                </li>

                @if (ViewBag.IsAuthenticated == true)
                {
                    <!-- Upload button -->
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm px-3 ms-2" asp-controller="Notes" asp-action="Upload">
                            <i class="bi bi-cloud-upload me-1"></i>Upload
                        </a>
                    </li>

                    <!-- User menu -->
                    <li class="nav-item dropdown ms-2">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 p-0" href="#" data-bs-toggle="dropdown">
                            @if (ViewBag.UserAvatar != null)
                            {
                                <img src="@ViewBag.UserAvatar" class="avatar-sm rounded-circle" alt="avatar" />
                            }
                            else
                            {
                                <div class="avatar-sm rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold">
                                    @(((string?)ViewBag.UserName ?? "U")[0])
                                </div>
                            }
                            <span class="d-none d-lg-inline">@ViewBag.UserName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                <i class="bi bi-person me-2"></i>My Profile
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit">
                                <i class="bi bi-pencil me-2"></i>Edit Profile
                            </a></li>
                            @if (ViewBag.IsAdmin == true)
                            {
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-warning" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-shield-check me-2"></i>Admin Panel
                                </a></li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </a></li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item ms-2">
                        <a class="btn btn-outline-primary btn-sm px-3" asp-controller="Auth" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item ms-1">
                        <a class="btn btn-primary btn-sm px-3" asp-controller="Auth" asp-action="Register">Register</a>
                    </li>
                }

                <!-- Dark mode toggle -->
                <li class="nav-item ms-2">
                    <button class="btn btn-sm btn-icon" id="darkModeToggle" title="Toggle dark mode">
                        <i class="bi bi-moon-fill" id="darkIcon"></i>
                    </button>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- ─── Toast Container ──────────────────────────────────────────────────────── -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index:1090">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast align-items-center text-bg-success border-0 show" role="alert">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast align-items-center text-bg-danger border-0 show" role="alert">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>

<!-- ─── Main Content ─────────────────────────────────────────────────────────── -->
<main>
    @RenderBody()
</main>

<!-- ─── Footer ───────────────────────────────────────────────────────────────── -->
<footer class="cnss-footer mt-5">
    <div class="container py-5">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-journal-bookmark-fill text-primary fs-4"></i>
                    <span class="fw-bold fs-5">CourseNotes</span>
                </div>
                <p class="text-muted small">The go-to platform for university students to share, discover and download course notes.</p>
            </div>
            <div class="col-lg-2 col-sm-6">
                <h6 class="fw-semibold mb-3">Platform</h6>
                <ul class="list-unstyled small text-muted">
                    <li class="mb-2"><a href="/" class="footer-link">Home</a></li>
                    <li class="mb-2"><a asp-controller="Notes" asp-action="Index" class="footer-link">Browse Notes</a></li>
                    <li class="mb-2"><a asp-controller="Courses" asp-action="Index" class="footer-link">Courses</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-sm-6">
                <h6 class="fw-semibold mb-3">Account</h6>
                <ul class="list-unstyled small text-muted">
                    @if (ViewBag.IsAuthenticated == true)
                    {
                        <li class="mb-2"><a asp-controller="Profile" asp-action="Index" class="footer-link">My Profile</a></li>
                        <li class="mb-2"><a asp-controller="Notes" asp-action="Upload" class="footer-link">Upload Note</a></li>
                    }
                    else
                    {
                        <li class="mb-2"><a asp-controller="Auth" asp-action="Login" class="footer-link">Login</a></li>
                        <li class="mb-2"><a asp-controller="Auth" asp-action="Register" class="footer-link">Register</a></li>
                    }
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="fw-semibold mb-3">Stay Updated</h6>
                <p class="text-muted small">Get the latest notes in your department.</p>
                <div class="input-group">
                    <input type="email" class="form-control" placeholder="your@email.edu" />
                    <button class="btn btn-primary">Subscribe</button>
                </div>
            </div>
        </div>
        <hr class="my-4 opacity-25" />
        <div class="d-flex flex-wrap justify-content-between align-items-center small text-muted">
            <span>&copy; @DateTime.Now.Year CourseNotes Platform. All rights reserved.</span>
            <span>Built with <i class="bi bi-heart-fill text-danger"></i> using ASP.NET Core &amp; EF Core</span>
        </div>
    </div>
</footer>

<!-- ─── Scripts ──────────────────────────────────────────────────────────────── -->
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<!-- Auto-dismiss toasts -->
<script>
    document.querySelectorAll('.toast.show').forEach(el => {
        setTimeout(() => new bootstrap.Toast(el, { delay: 4000 }).show(), 100);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
